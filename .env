# Database
DATABASE_URL=file:./tls.db

# ACME
ACME_EMAIL=your-email@example.com
ACME_DIRECTORY=https://your-acme-directory.example/directory

# Example base URL for documentation snippets
API_BASE_URL=http://your-host:8080

# Server
SERVER_ADDR=:8080
HTTP_ADDR=:80
TLS_ADDR=:443

# DNS Server
DNS_ADDR=:53

# Dynamic Domain
BASE_DOMAIN=your-domain.example
CERTMAGIC_STORAGE_PATH=./certmagic-data

# Auth
AUTH_TOKEN=your-secret-token-here

# Logging
LOG_LEVEL=info
